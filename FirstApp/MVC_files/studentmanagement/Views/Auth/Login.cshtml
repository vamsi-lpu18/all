<div style="max-width:400px;margin:40px auto;padding:30px;border-radius:8px;background:#f9f9f9;box-shadow:0 2px 8px #ccc;">
    <h2 style="color:#2980b9;text-align:center;">Login</h2>
    <form method="post" style="margin-top:20px;">
        <label style="font-weight:bold;">Username:</label>
        <input type="text" name="username" style="width:100%;padding:8px;margin-bottom:10px;border-radius:4px;border:1px solid #ccc;" />
        <label style="font-weight:bold;">Password:</label>
        <input type="password" name="password" style="width:100%;padding:8px;margin-bottom:10px;border-radius:4px;border:1px solid #ccc;" />
        <button type="submit" style="width:100%;padding:10px;background:#2980b9;color:#fff;border:none;border-radius:4px;font-weight:bold;">Login</button>
    </form>
    @if (ViewBag.Error != null)
    {
        <p style="color:red;text-align:center;margin-top:10px;">@ViewBag.Error</p>
    }
    @if (ViewBag.Token != null)
    {
        <p style="color:#27ae60;text-align:center;margin-top:10px;">JWT Token: @ViewBag.Token</p>
    }
</div>
