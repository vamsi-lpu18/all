<div style="max-width:400px;margin:40px auto;padding:30px;border-radius:8px;background:#eaf6ff;box-shadow:0 2px 8px #ccc;">
    <h2 style="color:#27ae60;text-align:center;">Login Successful</h2>
    <p style="text-align:center;">Welcome, student!</p>
    <p style="color:#2980b9;text-align:center;">Your JWT Token: @ViewBag.Token</p>
    <ul style="list-style:none;padding:0;margin-top:20px;">
        <li><a style="color:#2980b9;font-weight:bold;display:block;margin-bottom:10px;text-align:center;" href="/student/idcard/@ViewBag.StudentId">View ID Card</a></li>
        <li><a style="color:#f39c12;font-weight:bold;display:block;margin-bottom:10px;text-align:center;" href="/student/marks/@ViewBag.StudentId">View Marks</a></li>
        <li><a style="color:#27ae60;font-weight:bold;display:block;margin-bottom:10px;text-align:center;" href="/student/result/@ViewBag.StudentId">View Semester Result</a></li>
        <li><a style="color:#e74c3c;font-weight:bold;display:block;margin-bottom:10px;text-align:center;" href="/auth/logout">Logout</a></li>
    </ul>
</div>
