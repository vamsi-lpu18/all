@model studentmanagement.Models.Student
<div style="border:1px solid #333; padding:20px; width:320px; background:#f9f9f9; border-radius:8px; margin:40px auto; box-shadow:0 2px 8px #ccc;">
    <h2 style="color:#2c3e50; text-align:center;">Student ID Card</h2>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Roll No:</strong> @Model.RollNo</p>
    <p><strong>Semester:</strong> @Model.Semester</p>
    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
    {
        <img src="@Model.PhotoUrl" alt="Student Photo" style="width:100px; border-radius:50px; display:block; margin:10px auto;" />
    }
</div>
