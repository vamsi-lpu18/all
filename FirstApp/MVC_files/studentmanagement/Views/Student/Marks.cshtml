@model studentmanagement.Models.Student
<div style="border:1px solid #333; padding:20px; width:320px; background:#fffbe6; border-radius:8px; margin:40px auto; box-shadow:0 2px 8px #ccc;">
    <h2 style="color:#f39c12; text-align:center;">Marks</h2>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Marks:</strong> <span style="color:#e74c3c; font-weight:bold;">@Model.Marks</span></p>
</div>
