@model studentmanagement.Models.Student
<div style="border:1px solid #333; padding:20px; width:320px; background:#eaf6ff; border-radius:8px; margin:40px auto; box-shadow:0 2px 8px #ccc;">
    <h2 style="color:#2980b9; text-align:center;">Semester Result</h2>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Roll No:</strong> @Model.RollNo</p>
    <p><strong>Semester:</strong> @Model.Semester</p>
    <p><strong>Marks:</strong> <span style="color:#27ae60; font-weight:bold;">@Model.Marks</span></p>
</div>
