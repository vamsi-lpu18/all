@model admission_form.Models.AdmissionModel
@{ ViewData["Title"] = "Delete Admission"; }

<div class="mb-8 flex items-center gap-4">
    <a asp-action="List" class="p-2 rounded-lg hover:bg-slate-200 transition text-slate-500" title="Back">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-3xl font-bold text-white">Delete Admission</h1>
</div>

<div class="max-w-lg">
    <!-- Warning banner -->
    <div class="flex items-start gap-3 bg-red-50 border border-red-200 rounded-xl px-5 py-4 mb-6">
        <svg class="w-5 h-5 text-red-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
        <div>
            <p class="text-sm font-semibold text-red-700">This action cannot be undone.</p>
            <p class="text-sm text-red-600 mt-0.5">The student record and all associated data will be permanently removed.</p>
        </div>
    </div>

    <!-- Student card -->
    <div class="glass rounded-2xl shadow p-6 mb-6">
        <div class="flex items-center gap-4 mb-5">
            @if (Model.ProfileImage != null)
            {
                <img src="@Url.Action("GetImage", new { id = Model.Id })" alt="@Model.Name"
                     class="w-16 h-16 object-cover rounded-full ring-2 ring-red-200" />
            }
            else
            {
                <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center">
                    <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                </div>
            }
            <div>
                <p class="font-bold text-white text-lg">@Model.Name</p>
                <p class="text-sm text-slate-300">Student ID: @Model.Id</p>
            </div>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
            <div>
                <dt class="text-slate-400 font-medium">Age</dt>
                <dd class="text-slate-200 font-semibold">@(Model.Age?.ToString() ?? "—")</dd>
            </div>
            <div>
                <dt class="text-slate-400 font-medium">Phone</dt>
                <dd class="text-slate-200 font-semibold">@Model.PhoneNumber</dd>
            </div>
            <div class="col-span-2">
                <dt class="text-slate-400 font-medium">Email</dt>
                <dd class="text-slate-200 font-semibold">@(Model.Email ?? "—")</dd>
            </div>
        </dl>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex items-center gap-4">
        <button type="submit"
                class="bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-2.5 rounded-lg shadow-sm transition text-sm">
            Yes, Delete Permanently
        </button>
        <a asp-action="List" class="text-sm text-slate-300 hover:text-white transition">Cancel</a>
    </form>
</div>
