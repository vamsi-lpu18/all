@model admission_form.Models.AdmissionModel
@{ ViewData["Title"] = "New Admission"; }

<!-- Page header -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-white">New Admission</h1>
    <p class="text-slate-300 mt-1">Fill in the details below to register a new student.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Form card -->
    <div class="lg:col-span-2">
        <div class="glass rounded-2xl shadow p-8 hover:animate-spin  transition">
            <form id="admissionForm" asp-action="Submit" method="post" enctype="multipart/form-data" novalidate>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <!-- Name -->
                    <div class="sm:col-span-2">
                        <label for="Name" class="block text-sm font-semibold text-slate-700 mb-1.5">Full Name <span class="text-red-500">*</span></label>
                        <input type="text" id="Name" name="Name" value="@Model?.Name"
                           class="w-full border rounded-lg px-4 py-2.5 text-sm transition"
                               placeholder="e.g. John Smith" maxlength="100" />
                        <span class="field-error" id="err-Name">Full name is required (max 100 characters).</span>
                    </div>

                    <!-- Age -->
                    <div>
                        <label for="Age" class="block text-sm font-semibold text-slate-700 mb-1.5">Age <span class="text-red-500">*</span></label>
                        <input type="number" id="Age" name="Age" value="@Model?.Age"
                           class="w-full border rounded-lg px-4 py-2.5 text-sm transition"
                               placeholder="18" min="1" max="120" />
                        <span class="field-error" id="err-Age">Age must be between 1 and 120.</span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="PhoneNumber" class="block text-sm font-semibold text-slate-700 mb-1.5">Phone Number <span class="text-red-500">*</span></label>
                        <input type="text" id="PhoneNumber" name="PhoneNumber" value="@Model?.PhoneNumber"
                           class="w-full border rounded-lg px-4 py-2.5 text-sm transition"
                               placeholder="0300-1234567" maxlength="10" />
                        <span class="field-error" id="err-PhoneNumber">Phone number is required (max 10 characters).</span>
                    </div>

                    <!-- Email -->
                    <div class="sm:col-span-2">
                        <label for="Email" class="block text-sm font-semibold text-slate-700 mb-1.5">Email Address</label>
                        <input type="email" id="Email" name="Email" value="@Model?.Email"
                           class="w-full border rounded-lg px-4 py-2.5 text-sm transition"
                               placeholder="john@example.com" maxlength="100" />
                        <span class="field-error" id="err-Email">Please enter a valid email address.</span>
                    </div>

                    <!-- Profile Image -->
                    <div class="sm:col-span-2">
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Profile Photo <span class="text-slate-400 font-normal">(JPG or PNG &bull; max 5 MB)</span></label>
                        <div class="file-upload-area rounded-xl p-6 text-center relative" id="dropZone">
                            <input type="file" name="profileImage" id="profileImage" accept=".jpg,.jpeg,.png"
                                   class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                            <div id="uploadPlaceholder">
                                <svg class="w-10 h-10 text-indigo-400 mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
                                <p class="text-sm text-slate-600">Drag &amp; drop or <span class="text-brand-600 font-semibold">click to browse</span></p>
                                <p class="text-xs text-slate-400 mt-1">JPG, PNG &mdash; up to 5 MB</p>
                            </div>
                            <div id="imagePreview" class="hidden">
                                <img id="previewImg" src="#" alt="Preview" class="w-24 h-24 object-cover rounded-full mx-auto mb-2 ring-4 ring-indigo-100" />
                                <p id="previewName" class="text-xs text-slate-500"></p>
                            </div>
                        </div>
                        <span class="field-error" id="err-profileImage">Only JPG/PNG files under 5 MB are allowed.</span>
                    </div>
                </div>

                <div class="mt-8 flex items-center gap-4">
                    <button type="submit"
                            class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-8 py-2.5 rounded-lg shadow-sm transition text-sm">
                        Submit Application
                    </button>
                    <a asp-action="List" class="text-sm text-slate-300 hover:text-white transition">View all students &rarr;</a>
                </div>

            </form>
        </div>
    </div>

    <!-- Side info card -->
    <div class="lg:col-span-1">
        <div class="bg-brand-600 rounded-2xl p-6 text-white shadow">
            <h3 class="font-semibold text-lg mb-3">Admission Guidelines</h3>
            <ul class="space-y-2 text-indigo-100 text-sm">
                <li class="flex gap-2"><span class="mt-0.5">&#10003;</span> Full name is mandatory and must not exceed 100 characters.</li>
                <li class="flex gap-2"><span class="mt-0.5">&#10003;</span> Age must be a number between 1 and 120.</li>
                <li class="flex gap-2"><span class="mt-0.5">&#10003;</span> Phone number must be at most 10 characters.</li>
                <li class="flex gap-2"><span class="mt-0.5">&#10003;</span> Email address, if provided, must be in a valid format.</li>
                <li class="flex gap-2"><span class="mt-0.5">&#10003;</span> Profile photo must be JPG or PNG and under 5 MB.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // ---- helpers ----
    function showError(id, msg) {
        const el = document.getElementById('err-' + id);
        const input = document.getElementById(id);
        if (el) { el.textContent = msg || el.textContent; el.classList.add('show'); }
        if (input) input.classList.add('invalid');
    }
    function clearError(id) {
        const el = document.getElementById('err-' + id);
        const input = document.getElementById(id);
        if (el) el.classList.remove('show');
        if (input) input.classList.remove('invalid');
    }

    // ---- per-field blur validation ----
    function validateName() {
        const v = document.getElementById('Name').value.trim();
        if (!v) { showError('Name', 'Full name is required.'); return false; }
        if (v.length > 100) { showError('Name', 'Max 100 characters.'); return false; }
        clearError('Name'); return true;
    }
    function validateAge() {
        const v = parseInt(document.getElementById('Age').value, 10);
        if (isNaN(v) || v < 1 || v > 120) { showError('Age', 'Age must be between 1 and 120.'); return false; }
        clearError('Age'); return true;
    }
    function validatePhone() {
        const v = document.getElementById('PhoneNumber').value.trim();
        if (!v) { showError('PhoneNumber', 'Phone number is required.'); return false; }
        if (v.length > 10) { showError('PhoneNumber', 'Max 10 characters.'); return false; }
        clearError('PhoneNumber'); return true;
    }
    function validateEmail() {
        const v = document.getElementById('Email').value.trim();
        if (v && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v)) { showError('Email', 'Enter a valid email address.'); return false; }
        clearError('Email'); return true;
    }
    function validateImage(file) {
        if (!file) { clearError('profileImage'); return true; }
        const allowed = ['image/jpeg', 'image/png'];
        if (!allowed.includes(file.type)) { showError('profileImage', 'Only JPG and PNG images are allowed.'); return false; }
        if (file.size > 5 * 1024 * 1024) { showError('profileImage', 'Image must be smaller than 5 MB.'); return false; }
        clearError('profileImage'); return true;
    }

    document.getElementById('Name').addEventListener('blur', validateName);
    document.getElementById('Age').addEventListener('blur', validateAge);
    document.getElementById('PhoneNumber').addEventListener('blur', validatePhone);
    document.getElementById('Email').addEventListener('blur', validateEmail);

    // Image preview + validation
    const imgInput = document.getElementById('profileImage');
    imgInput.addEventListener('change', function () {
        const file = this.files[0];
        if (!validateImage(file)) return;
        if (file) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('previewName').textContent = file.name;
                document.getElementById('uploadPlaceholder').classList.add('hidden');
                document.getElementById('imagePreview').classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }
    });

    // Form submit gating
    document.getElementById('admissionForm').addEventListener('submit', function (e) {
        const file = imgInput.files[0];
        const ok = [validateName(), validateAge(), validatePhone(), validateEmail(), validateImage(file)];
        if (ok.includes(false)) e.preventDefault();
    });
})();
</script>
}
