@model IEnumerable<admission_form.Models.AdmissionModel>
@{ ViewData["Title"] = "All Students"; }

<!-- Page header -->
<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <h1 class="text-3xl font-bold text-white">All Students</h1>
        <p class="text-slate-300 mt-1 text-sm">@Model.Count() student(s) registered</p>
    </div>
    <a asp-action="Index"
       class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-semibold px-5 py-2.5 rounded-lg shadow-sm transition text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        New Admission
    </a>
</div>

@if (!Model.Any())
{
    <div class="glass rounded-2xl shadow p-16 text-center">
        <svg class="w-14 h-14 text-slate-400 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
        <p class="text-slate-200 text-lg font-medium">No students registered yet</p>
        <a asp-action="Index" class="mt-4 inline-block text-indigo-300 hover:text-white font-semibold text-sm">Add the first student &rarr;</a>
    </div>
}
else
{
    <div class="glass rounded-2xl border border-white/10 shadow overflow-hidden">
        <table class="w-full text-sm animate-spin">
            <thead>
                <tr class="border-b border-white/10" style="background:rgba(255,255,255,0.06);">
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">#</th>
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-4 py-4">Photo</th>
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-4 py-4">Name</th>
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-4 py-4">Age</th>
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-4 py-4">Email</th>
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-4 py-4">Phone</th>
                            <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-4 py-4">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-white/10 transition border-b border-white/5">
                        <td class="px-6 py-4 text-white font-mono text-xs">@item.Id</td>
                        <td class="px-4 py-4">
                            @if (item.ProfileImage != null && item.ProfileImage.Length > 0)
                            {
                                <img src="data:@item.ImageContentType;base64,@Convert.ToBase64String(item.ProfileImage)"
                                     alt="@item.Name"
                                     class="w-12 h-12 object-cover rounded-full ring-2 ring-indigo-300 shadow" />
                            }
                            else
                            {
                                <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.15);">
                                    <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                                </div>
                            }
                        </td>
                        <td class="px-4 py-4 font-semibold text-white">@item.Name</td>
                        <td class="px-4 py-4 text-slate-300">@item.Age</td>
                        <td class="px-4 py-4 text-slate-300">@(item.Email ?? "—")</td>
                        <td class="px-4 py-4 text-slate-300">@item.PhoneNumber</td>
                        <td class="px-4 py-4">
                            <div class="flex items-center gap-3">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="inline-flex items-center gap-1 text-indigo-300 hover:text-white font-medium transition text-xs">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
                                    Edit
                                </a>
                                <a asp-action="IdCard" asp-route-id="@item.Id" target="_blank"
                                   class="inline-flex items-center gap-1 text-emerald-400 hover:text-emerald-200 font-medium transition text-xs">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                                    ID Card
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="inline-flex items-center gap-1 text-red-400 hover:text-red-200 font-medium transition text-xs">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
