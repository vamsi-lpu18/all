@model app.Models.EmployeeViewModel

@{
    ViewData["Title"] = "Employee Directory";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5">Employee Directory</h1>
            <hr class="my-3">
        </div>
    </div>
    
    <!-- Employee Table -->
    <div class="row">
        <div class="col-12">
            <div class="table-responsive shadow-sm">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 8%;">ID</th>
                            <th style="width: 15%;">Name</th>
                            <th style="width: 12%;">Department</th>
                            <th style="width: 12%;">Position</th>
                            <th style="width: 12%;">Salary</th>
                            <th style="width: 18%;">Email</th>
                            <th style="width: 13%;">Phone</th>
                            <th style="width: 14%;">Joining Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model.Employees)
                        {
                            <tr>
                                <td>@employee.EmployeeId</td>
                                <td>@employee.EmployeeName</td>
                                <td><span class="badge bg-info text-dark">@employee.Department</span></td>
                                <td>@employee.Position</td>
                                <td><strong>@employee.Salary.ToString("N2")</strong></td>
                                <td>@employee.Email</td>
                                <td>@employee.PhoneNumber</td>
                                <td>@employee.JoiningDate.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination Info -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <p class="text-muted mb-0">
                    <strong>Showing @Model.Employees.Count() of @Model.Pager.TotalItems  Employees </strong> | 
                    <strong>Page @Model.Pager.CurrentPage of @Model.Pager.TotalPages</strong>
                </p>
            </div>
        </div>
    </div>

    <!-- Pagination Controls -->
    @if (Model.Pager.TotalPages > 1)
    {
        <div class="row mt-4">
            <div class="col-12">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        <!-- First Page Link -->
                        @if (Model.Pager.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { page = 1 })">
                                    <strong>&laquo;</strong> First
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><strong>&laquo;</strong> First</span>
                            </li>
                        }

                        <!-- Previous Page Link -->
                        @if (Model.Pager.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { page = Model.Pager.CurrentPage - 1 })">
                                    Previous
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Previous</span>
                            </li>
                        }

                        <!-- Page Numbers -->
                        @for (int i = Model.Pager.StartPage; i <= Model.Pager.EndPage; i++)
                        {
                            @if (i > 0 && i <= Model.Pager.TotalPages)
                            {
                                @if (i == Model.Pager.CurrentPage)
                                {
                                    <li class="page-item active">
                                        <a class="page-link" href="@Url.Action("Index", "Home", new { page = i })">
                                            @i
                                        </a>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("Index", "Home", new { page = i })">@i</a>
                                    </li>
                                }
                            }
                        }

                        <!-- Next Page Link -->
                        @if (Model.Pager.CurrentPage < Model.Pager.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { page = Model.Pager.CurrentPage + 1 })">
                                    Next
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Next</span>
                            </li>
                        }

                        <!-- Last Page Link -->
                        @if (Model.Pager.CurrentPage < Model.Pager.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", "Home", new { page = Model.Pager.TotalPages })">
                                    Last <strong>&raquo;</strong>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Last <strong>&raquo;</strong></span>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .container-fluid {
        max-width: 1400px;
        margin-left: auto;
        margin-right: auto;
        padding: 0 20px;
    }

    h1 {
        color: #2c3e50;
        font-weight: 600;
    }

    .table {
        margin-bottom: 0;
        background-color: white;
    }

    .table thead {
        background-color: #2c3e50;
    }

    .table thead th {
        color: white;
        font-weight: 600;
        border-color: #2c3e50;
        padding: 15px;
        font-size: 0.95rem;
    }

    .table tbody td {
        padding: 12px 15px;
        vertical-align: middle;
        border-color: #e9ecef;
    }

    .table tbody tr {
        transition: background-color 0.3s ease;
    }

    .table-hover tbody tr:hover {
        background-color: #f1f3f5;
    }

    .shadow-sm {
        border: 1px solid #dee2e6;
    }

    .pagination {
        gap: 3px;
        margin-top: 20px;
    }

    .page-link {
        color: #0d6efd;
        border: 1px solid #dee2e6;
        padding: 0.5rem 0.75rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .page-link:hover:not(.disabled .page-link) {
        background-color: #e9ecef;
        border-color: #0d6efd;
        color: #0d6efd;
    }

    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
        font-weight: 600;
    }

    .page-item.disabled .page-link {
        color: #6c757d;
        cursor: not-allowed;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.4rem 0.6rem;
    }

    .text-muted {
        font-size: 0.95rem;
    }
</style>
