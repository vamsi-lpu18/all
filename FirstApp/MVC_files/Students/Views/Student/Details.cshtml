@model Students.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<h2>Student Details</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Student ID</dt>
    <dd class="col-sm-9">@Model.StudentId</dd>

    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@(Model.Phone ?? "-")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">@Model.Status</span>
    </dd>

    <dt class="col-sm-3">Join Date</dt>
    <dd class="col-sm-9">@Model.JoinDate.ToString("MMM dd, yyyy")</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</dd>
</dl>

@if (Model.Enrollments.Any())
{
    <h5 class="mt-4">Enrolled Courses</h5>
    <table class="table table-bordered table-sm">
        <thead class="table-secondary">
            <tr>
                <th>Course</th>
                <th>Payment Status</th>
                <th>Paid Amount</th>
                <th>Enrolled On</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var enrollment in Model.Enrollments)
            {
                <tr>
                    <td>@enrollment.Course?.Title</td>
                    <td>@enrollment.PaymentStatus</td>
                    <td>@enrollment.PaidAmount.ToString("C")</td>
                    <td>@enrollment.CreatedAt.ToString("MMM dd, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex gap-2 mt-3">
    <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
