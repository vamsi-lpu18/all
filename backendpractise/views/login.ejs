<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 min-h-screen flex items-center justify-center">
  <form method="post" action="/login" class="bg-zinc-800 p-8 rounded-xl shadow-lg text-white w-[400px]">
    <h1 class="text-3xl text-center mb-6">Welcome</h1>

    <input
      type="email"
      name="email"
      placeholder="Enter email"
      required
      class="bg-gray-800 outline-none text-white rounded-xl p-4 mb-4 w-full"
    />

    <input
      type="password"
      name="password"
      placeholder="Enter password"
      required
      class="bg-gray-800 outline-none text-white rounded-xl p-4 mb-6 w-full"
    />

    <button
      type="submit"
      class="bg-blue-500 hover:bg-blue-600 transition text-white rounded-xl p-3 w-full"
    >
      Login
    </button>
  </form>
</body>
</html>
